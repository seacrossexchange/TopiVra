# ============================================================
# TopiVra Git Attributes
# 用于统一行尾符和文件处理
# ============================================================

# 自动检测文本文件并规范化行尾
* text=auto

# ==================== 源代码文件 ====================
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.prisma text eol=lf

# ==================== 配置文件 ====================
*.conf text eol=lf
*.config text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# ==================== Shell 脚本 ====================
*.sh text eol=lf
*.bash text eol=lf

# ==================== Windows 脚本 ====================
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ==================== Web 文件 ====================
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.svg text eol=lf

# ==================== 二进制文件 ====================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# ==================== 锁文件 ====================
package-lock.json -diff
yarn.lock -diff
pnpm-lock.yaml -diff

# ==================== 导出忽略 ====================
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
docs/ export-ignore
*.md export-ignore




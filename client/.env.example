# ============================================
# Topter C2C Client — 环境变量
# REQUIRED = 必填  OPTIONAL = 可选
# ============================================

# ---------- API (REQUIRED) ----------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------- OAuth (OPTIONAL) ----------
VITE_GOOGLE_CLIENT_ID=
VITE_TELEGRAM_BOT_NAME=

# ---------- Feature Flags (OPTIONAL) ----------
VITE_ENABLE_TELEGRAM_LOGIN=false
VITE_ENABLE_2FA=false

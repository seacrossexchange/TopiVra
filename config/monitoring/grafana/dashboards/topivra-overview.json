{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "TopiVra 平台总览仪表盘",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "业务指标",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 1000 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "订单总数",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(orders_created_total[24h]))",
        "legendFormat": "24h 新增"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "green", "value": 50 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "支付成功（24h）",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(payments_success_total[24h]))",
        "legendFormat": "支付成功"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "支付失败（24h）",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(payments_failed_total[24h]))",
        "legendFormat": "支付失败"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "自动发货失败（24h）",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(auto_delivery_failed_total[24h]))",
        "legendFormat": "发货失败"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "WebSocket 连接数",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "websocket_connections_active",
        "legendFormat": "活跃连接"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "API 性能",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP 请求速率",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(http_requests_total[1m])) by (route)",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP 响应时间 P95",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
        "legendFormat": "P95 {{route}}"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "系统资源",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 15 },
      "id": 21,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "CPU 使用率",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 15 },
      "id": 22,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "内存使用率",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory %"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "id": 23,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Node.js 堆内存",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "已用"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "总量"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 30,
      "title": "错误率",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 31,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP 5xx 错误",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[1m])) by (route)",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisPlacement": "auto", "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 32,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "支付失败趋势",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(increase(payments_failed_total[5m])) by (method, reason)",
        "legendFormat": "{{method}} - {{reason}}"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["topivra", "overview"],
  "templating": {
    "list": [{
      "current": {},
      "hide": 0,
      "includeAll": false,
      "label": "Datasource",
      "multi": false,
      "name": "datasource",
      "options": [],
      "query": "prometheus",
      "refresh": 1,
      "type": "datasource"
    }]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TopiVra 平台总览",
  "uid": "topivra-overview",
  "version": 1
}










{
  "name": "topivra",
  "version": "1.0.0",
  "description": "Enterprise digital account trading platform",
  "main": "index.js",
  "scripts": {
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "security:check": "npm run audit && npm run snyk:test",
    "snyk:test": "snyk test --severity-threshold=high",
    "snyk:monitor": "snyk monitor",
    "verify": "node scripts/verify-delivery.ps1",
    "precommit": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/topivra/topivra.git"
  },
  "keywords": [
    "trading-platform",
    "digital-accounts",
    "e-commerce",
    "nestjs",
    "react",
    "typescript"
  ],
  "author": "TopiVra Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/topivra/topivra/issues"
  },
  "homepage": "https://github.com/topivra/topivra#readme",
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "snyk": "^1.1275.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}

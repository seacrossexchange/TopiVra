# ============================================
# Topter C2C Server — 环境变量
# REQUIRED = 必填  OPTIONAL = 可选
# ============================================

# ---------- Database (REQUIRED) ----------
DATABASE_URL="mysql://root:password@localhost:3306/topter_c2c"

# ---------- Redis (REQUIRED) ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT (REQUIRED) ----------
JWT_SECRET=your-jwt-secret-key-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# ---------- OAuth (OPTIONAL) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
TELEGRAM_BOT_TOKEN=

# ---------- SMTP (OPTIONAL) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------- App (REQUIRED) ----------
APP_PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_VERSION=v1

# ---------- Platform (REQUIRED) ----------
# 平台手续费率 (0.05 = 5%)
PLATFORM_FEE_RATE=0.05
# 最低提现金额
MIN_WITHDRAWAL_AMOUNT=10
# 提现手续费
WITHDRAWAL_FEE_RATE=0.01

# ---------- Business Config (REQUIRED) ----------
# 订单自动取消时间（分钟）
ORDER_AUTO_CANCEL_MINUTES=30
# 订单自动确认时间（天）
ORDER_AUTO_CONFIRM_DAYS=7
# 支付过期时间（分钟）
PAYMENT_EXPIRATION_MINUTES=30
# 最大退款天数
MAX_REFUND_DAYS=7

# ---------- Upload (OPTIONAL) ----------
# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# ---------- Payment (OPTIONAL) ----------
# USDT 支付配置
USDT_WALLET_ADDRESS=
USDT_CALLBACK_SECRET=
USDT_REQUIRED_CONFIRMATIONS=3

# 区块链 API 配置
TRON_API_KEY=
TRON_API_URL=https://api.trongrid.io
ETH_API_URL=https://api.etherscan.io
BSC_API_URL=https://api.bscscan.com
BLOCKCHAIN_API_KEY_ETHEREUM=
BLOCKCHAIN_API_KEY_BSC=

# USDT 合约地址
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
USDT_ERC20_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955

# 支付宝支付配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付配置
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=

# ---------- Alert (OPTIONAL) ----------
# Telegram 告警配置（用于发送系统错误告警）
# TELEGRAM_BOT_TOKEN 从 OAuth 部分获取
TELEGRAM_CHAT_ID=

# ---------- Sentry (OPTIONAL) ----------
# Sentry 错误追踪（npm i @sentry/node）
SENTRY_DSN=

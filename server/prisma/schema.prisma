// ==================== 商品 ====================

model Product {
  id         String @id @default(uuid())
  sellerId   String @map("seller_id")
  categoryId String @map("category_id")

  // 基本信息
  title       String
  description String  @db.Text
  platform    String
  accountType String? @map("account_type")
  region      String?
  tags        Json?

  // 账号属性
  attributes Json?

  // 商品凭证（账号信息）
  credentials Json?

  // 价格
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  currency      String   @default("USD")

  // 库存
  stock     Int @default(1)
  soldCount Int @default(0) @map("sold_count")

  // 自动发货
  autoDeliver    Boolean @default(true) @map("auto_deliver")
  inventoryCount Int     @default(0) @map("inventory_count")

  // 图片
  images       Json?
  thumbnailUrl String? @map("thumbnail_url")

  // 状态
  status       ProductStatus @default(DRAFT)
  rejectReason String?       @map("reject_reason")
  auditedBy    String?       @map("audited_by")
  auditedAt    DateTime?     @map("audited_at")

  // SEO
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  // 统计
  viewCount     Int     @default(0) @map("view_count")
  favoriteCount Int     @default(0) @map("favorite_count")
  reviewCount   Int     @default(0) @map("review_count")
  rating        Decimal @default(0) @db.Decimal(2, 1)

  // 促销信息
  promotionLabel String?   @map("promotion_label")
  promotionStart DateTime? @map("promotion_start")
  promotionEnd   DateTime? @map("promotion_end")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  seller       User                  @relation(fields: [sellerId], references: [id])
  category     Category              @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  reviews      Review[]
  favorites    Favorite[]
  cartItems    CartItem[]
  inventories  ProductInventory[]
  //   translations ProductTranslation[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([platform])
  @@index([status])
  @@index([price])
  @@index([soldCount])
  @@index([sellerId, status])
  @@index([platform, status])
  @@index([createdAt])
  @@map("products")
}


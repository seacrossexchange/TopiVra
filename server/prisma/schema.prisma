  blogId    String   @map("blog_id")
  userId    String?  @map("user_id") // 可选，未登录用户为null
  ipAddress String   @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@index([blogId])
  @@index([userId])
  @@index([ipAddress, blogId])
  @@index([createdAt])
  @@map("blog_views")
}

// ==================== 站内消息系统 ====================

model Message {
  id             String  @id @default(uuid())
  conversationId String? @map("conversation_id")

  // 发送者和接收者
  senderId   String @map("sender_id")
  receiverId String @map("receiver_id")

  // 消息内容
  content     String      @db.Text
  messageType MessageType @default(TEXT)
  attachments Json?

  // 关联
  orderId   String? @map("order_id")
  productId String? @map("product_id")

  // 状态
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // 删除标记（软删除）
  senderDeleted   Boolean @default(false) @map("sender_deleted")
  receiverDeleted Boolean @default(false) @map("receiver_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系
  sender       User          @relation("MessageSender", fields: [senderId], references: [id])
  receiver     User          @relation("MessageReceiver", fields: [receiverId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([conversationId])
  @@index([receiverId, isRead])
  @@index([createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  ORDER_NOTIFICATION
}

// 消息会话
model Conversation {
  id String @id @default(uuid())

  // 参与者
  user1Id String @map("user1_id")
  user2Id String @map("user2_id")

  // 最后一条消息
  lastMessage   String?   @map("last_message")
  lastMessageAt DateTime? @map("last_message_at")

  // 未读计数
  user1Unread Int @default(0) @map("user1_unread")
  user2Unread Int @default(0) @map("user2_unread")

  // 关联订单
  orderId String? @map("order_id")

  // 关联消息
  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
  @@map("conversations")
}

// ==================== 卖家信用分系�?====================

model SellerCredit {
  id       String @id @default(uuid())
  sellerId String @unique @map("seller_id")

  // 基础信用分
  creditScore Int         @default(100) @map("credit_score") // 初始100分，满分200
  creditLevel CreditLevel @default(POOR)

  // 评分明细

  positivePoints Int @default(0) @map("positive_points") // 正面积分
  negativePoints Int @default(0) @map("negative_points") // 负面积分

  // 统计指标

  totalOrders     Int @default(0) @map("total_orders")
  completedOrders Int @default(0) @map("completed_orders")
  refundedOrders  Int @default(0) @map("refunded_orders")
  disputedOrders  Int @default(0) @map("disputed_orders")

  // 响应指标

  avgResponseTime Int     @default(0) @map("avg_response_time") // 平均响应时间（分钟）
  responseRate    Decimal @default(100.00) @map("response_rate") @db.Decimal(5, 2) // 响应�?

  // 评价指标

  avgRating    Decimal @default(5.0) @map("avg_rating") @db.Decimal(2, 1)
  fiveStarRate Decimal @default(0.00) @map("five_star_rate") @db.Decimal(5, 2) // 五星好评�?
  ratingCount  Int     @default(0) @map("rating_count") // 评价数量

  // 违规记录

  violations Int @default(0) // 违规次数
  warnings   Int @default(0) // 警告次数

  // 时间戳
  lastCalculated DateTime @default(now()) @map("last_calculated")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([creditScore])
  @@index([creditLevel])
  @@map("seller_credits")
}

enum CreditLevel {
  POOR
  NORMAL
  GOOD
  EXCELLENT
  PREMIUM
}

// 信用分变动记录
model CreditTransaction {
  id       String @id @default(uuid())
  sellerId String @map("seller_id")

  // 变动信息
  change      Int // 正数为加分，负数为减分
  reason      CreditChangeReason
  description String?

  // 关联
  orderId  String? @map("order_id")
  reviewId String? @map("review_id")
  ticketId String? @map("ticket_id")

  scoreAfter Int @map("score_after")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sellerId])
  @@index([reason])
  @@index([createdAt])
  @@map("credit_transactions")
}

enum CreditChangeReason {
  ORDER_COMPLETED
  FIVE_STAR_REVIEW
  GOOD_REVIEW
  QUICK_RESPONSE
  LONG_TERM_SELLER
  ORDER_REFUNDED
  ORDER_DISPUTED
  BAD_REVIEW
  SLOW_RESPONSE
  COMPLAINT
  VIOLATION
  FRAUD_DETECTED
}

// ==================== 风控系统 ====================

model RiskAssessment {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // 风险类型
  type String // ORDER, WITHDRAWAL, LOGIN �?
  // 风险评估结果

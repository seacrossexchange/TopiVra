  @@map("system_configs")
}

// ==================== 博客系统 ====================

model Blog {
  id         String  @id @default(uuid())
  authorId   String  @map("author_id")
  categoryId String? @map("category_id")

  // 基本信息
  title      String  @db.VarChar(200)
  slug       String  @unique @db.VarChar(200)
  excerpt    String? @db.Text
  content    String  @db.Text
  coverImage String? @map("cover_image") @db.VarChar(500)

  // 状态
  status BlogStatus @default(DRAFT)

  // SEO
  metaTitle       String? @map("meta_title") @db.VarChar(200)
  metaDescription String? @map("meta_description") @db.VarChar(500)

  // 统计
  viewCount    Int @default(0) @map("view_count")
  likeCount    Int @default(0) @map("like_count")
  commentCount Int @default(0) @map("comment_count")
  readingTime  Int @default(0) @map("reading_time") // 阅读时间（分钟）

  // 内容格式
  contentType ContentType @default(MARKDOWN) @map("content_type")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // 关联
  author       User               @relation(fields: [authorId], references: [id])
  category     Category?          @relation(fields: [categoryId], references: [id])
  tags         BlogTag[]
  comments     BlogComment[]
  likes        BlogLike[]
  views        BlogView[]
  //   translations BlogTranslation[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@index([viewCount])
  @@map("blogs")
}


  factors Json // 风险因素列表

  // 行为数据
  ipAddress String? @map("ip_address")
  deviceId  String? @map("device_id")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("risk_assessments")

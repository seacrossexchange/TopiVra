enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ON_SALE
  OFF_SALE
  SOLD_OUT
}

// ==================== 订单 ====================

model Order {
  id      String @id @default(uuid())
  orderNo String @unique @map("order_no")
  buyerId String @map("buyer_id")

  // 金额
  totalAmount Decimal @map("total_amount") @db.Decimal(10, 2)
  payAmount   Decimal @map("pay_amount") @db.Decimal(10, 2)
  commission  Decimal @default(0.00) @db.Decimal(10, 2)
  currency    String  @default("USD")

  // 支付
  paymentMethod String?       @map("payment_method")
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  paidAt        DateTime?     @map("paid_at")

  // 订单状态
  orderStatus OrderStatus @default(CREATED) @map("order_status")

  // 退款
  refundReason String?   @map("refund_reason") @db.Text
  refundAmount Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundedAt   DateTime? @map("refunded_at")

  // 备注
  buyerRemark String? @map("buyer_remark")
  adminRemark String? @map("admin_remark")

  // 自动操作
  autoCancelAt  DateTime? @map("auto_cancel_at")
  autoConfirmAt DateTime? @map("auto_confirm_at")

  completedAt DateTime? @map("completed_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  buyer          User               @relation("BuyerOrders", fields: [buyerId], references: [id])
  orderItems     OrderItem[]
  payments       Payment[]
  reviews        Review[]
  refundRequests RefundRequest[]
  inventories    ProductInventory[]

  @@index([buyerId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([buyerId, orderStatus])
  @@index([createdAt])
  @@map("orders")
}

enum PaymentStatus {
  UNPAID
  PAYING
  PAID
  REFUNDED
  PARTIAL_REFUND
}

enum OrderStatus {
  CREATED
  PENDING_PAYMENT
  PAID
  DELIVERED
  COMPLETED
  REFUNDING
  REFUNDED
  CANCELLED
  CLOSED
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")
  sellerId  String @map("seller_id")

  // 快照
  productTitle    String @map("product_title")
  productSnapshot Json?  @map("product_snapshot")

  // 金额
  quantity  Int     @default(1)
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  // 交付
  deliveredCredentials Json?     @map("delivered_credentials")
  deliveredAt          DateTime? @map("delivered_at")
  deliveryConfirmed    Boolean   @default(false) @map("delivery_confirmed")
  confirmedAt          DateTime? @map("confirmed_at")

  // 自动发货
  inventoryId   String? @map("inventory_id")
  autoDelivered Boolean @default(false) @map("auto_delivered")

  // 卖家结算
  sellerAmount     Decimal   @map("seller_amount") @db.Decimal(10, 2)
  commissionAmount Decimal   @map("commission_amount") @db.Decimal(10, 2)
  commissionRate   Decimal   @map("commission_rate") @db.Decimal(4, 2)
  settled          Boolean   @default(false)
  settledAt        DateTime? @map("settled_at")

  createdAt DateTime @default(now()) @map("created_at")

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product           @relation(fields: [productId], references: [id])
  seller    User              @relation("SellerOrderItems", fields: [sellerId], references: [id])
  inventory ProductInventory? @relation(fields: [inventoryId], references: [id])

  @@index([orderId])
  @@index([sellerId])
  @@index([productId])
  @@index([sellerId, settled])
  @@map("order_items")
}

// ==================== 支付 ====================

model Payment {
  id        String @id @default(uuid())
  paymentNo String @unique @map("payment_no")
  orderId   String @map("order_id")
  userId    String @map("user_id")

  // 支付信息
  method   String
  amount   Decimal             @db.Decimal(10, 2)
  currency String
  status   PaymentRecordStatus @default(PENDING)

  // 第三方信息
  providerOrderId String? @map("provider_order_id")
  providerData    Json?   @map("provider_data")

  // USDT 专用
  walletAddress String?  @map("wallet_address")
  txHash        String?  @map("tx_hash")
  usdtAmount    Decimal? @map("usdt_amount") @db.Decimal(12, 6)
  exchangeRate  Decimal? @map("exchange_rate") @db.Decimal(10, 4)

  expiredAt DateTime? @map("expired_at")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@index([status, createdAt])
  @@map("payments")
}

enum PaymentRecordStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
}

// ==================== 账号库存系统 ====================

model ProductInventory {
  id        String @id @default(uuid())
  productId String @map("product_id")
  sellerId  String @map("seller_id")

  // 账号信息（加密存储）
  accountData String @map("account_data") @db.Text
  accountHash String @unique @map("account_hash")

  // 账号格式化数据（JSON）
  accountInfo Json? @map("account_info")

  // 状态
  status InventoryStatus @default(AVAILABLE)

  // 订单关联
  orderId     String?   @map("order_id")
  orderItemId String?   @map("order_item_id")
  soldAt      DateTime? @map("sold_at")

  // 失效管理
  isValid       Boolean   @default(true) @map("is_valid")
  invalidReason String?   @map("invalid_reason")
  invalidAt     DateTime? @map("invalid_at")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller     User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order      Order?      @relation(fields: [orderId], references: [id])
  orderItems OrderItem[]

  @@index([productId, status])
  @@index([sellerId, status])
  @@index([accountHash])
  @@index([orderId])
  @@map("product_inventories")
}

enum InventoryStatus {
  AVAILABLE // 可用
  RESERVED // 预留（订单创建但未支付）
  SOLD // 已售�?  INVALID // 失效
}

// ==================== 购物�?====================

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("cart_items")
}

// ==================== 工单系统 ====================

model Ticket {
  id       String  @id @default(uuid())
  ticketNo String  @unique @map("ticket_no")
  userId   String  @map("user_id")
  orderId  String? @map("order_id")

  // 工单信息
  type     TicketType
  subject  String
  content  String         @db.Text
  priority TicketPriority @default(MEDIUM)
  status   TicketStatus   @default(OPEN)

  // SLA
  slaLevel    String?   @map("sla_level")
  slaDeadline DateTime? @map("sla_deadline")

  // 分配
  assignedTo String? @map("assigned_to")

  // 时间
  resolvedAt DateTime? @map("resolved_at")
  closedAt   DateTime? @map("closed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // 关联
  user     User            @relation("UserTickets", fields: [userId], references: [id])
  assignee User?           @relation("AssignedTickets", fields: [assignedTo], references: [id])
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, priority])
  @@index([assignedTo])
  @@map("tickets")
}

enum TicketType {
  ORDER_ISSUE
  ACCOUNT_ISSUE
  PAYMENT_ISSUE
  SUGGESTION
  OTHER
}

enum TicketPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  senderId    String   @map("sender_id")
  content     String   @db.Text
  isInternal  Boolean  @default(false) @map("is_internal")
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

// ==================== 评价系统 ====================

model Review {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  productId String @map("product_id")
  sellerId  String @map("seller_id")
  orderId   String @unique @map("order_id")

  // 评价内容
  rating      Int
  content     String? @db.Text
  tags        Json?
  isAnonymous Boolean @default(false) @map("is_anonymous")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([productId, createdAt])
  @@index([sellerId])
  @@index([rating])
  @@map("reviews")
}

// ==================== 收藏系统 ====================

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("favorites")
}

// ==================== 通知系统 ====================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  content   String    @db.Text
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ==================== 提现系统 ====================

model Withdrawal {
  id           String @id @default(uuid())
  withdrawalNo String @unique @map("withdrawal_no")
  sellerId     String @map("seller_id")

  // 提现信息
  amount       Decimal @db.Decimal(10, 2)
  fee          Decimal @default(0.00) @db.Decimal(10, 2)
  actualAmount Decimal @map("actual_amount") @db.Decimal(10, 2)
  currency     String  @default("USD")

  // 收款方式
  method      String
  accountInfo Json   @map("account_info")

  // 状态
  status       WithdrawalStatus @default(PENDING)
  rejectReason String?          @map("reject_reason")
  auditedBy    String?          @map("audited_by")
  auditedAt    DateTime?        @map("audited_at")
  completedAt  DateTime?        @map("completed_at")

  // 打款凭证
  transferProof String? @map("transfer_proof")
  txHash        String? @map("tx_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  seller User @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@map("withdrawals")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

// ==================== 卖家资金流水 ====================

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([type])
  @@map("transactions")
}

model SellerTransaction {
  id           String          @id @default(uuid())
  sellerId     String          @map("seller_id")
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @map("balance_after") @db.Decimal(12, 2)
  currency     String          @default("USD")

  // 关联
  orderId      String? @map("order_id")
  orderItemId  String? @map("order_item_id")
  withdrawalId String? @map("withdrawal_id")

  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  seller User @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([type])
  @@map("seller_transactions")
}

enum TransactionType {
  INCOME
  COMMISSION
  WITHDRAWAL
  REFUND
  ADJUSTMENT
}

// ==================== 退款系�?====================

model RefundRequest {
  id          String  @id @default(uuid())
  refundNo    String  @unique @map("refund_no")
  orderId     String  @map("order_id")
  orderItemId String? @map("order_item_id")
  userId      String  @map("user_id")
  sellerId    String  @map("seller_id")

  // 退款信息
  refundType  String  @default("REFUND_ONLY") @map("refund_type") // REFUND_ONLY, RETURN_REFUND
  reason      String  @db.Text
  description String? @db.Text
  evidence    Json? // 退款凭证图�?
  // 金额
  refundAmount Decimal @map("refund_amount") @db.Decimal(10, 2)
  currency     String  @default("USD")

  // 状态
  status RefundStatus @default(PENDING)

  // 卖家响应
  sellerResponse    String?   @map("seller_response") @db.Text
  sellerRespondedAt DateTime? @map("seller_responded_at")

  // 平台介入
  escalateReason String?   @map("escalate_reason") @db.Text
  escalatedAt    DateTime? @map("escalated_at")

  // 管理员处理
  adminResponse     String?   @map("admin_response") @db.Text
  processedBy       String?   @map("processed_by")
  processedAt       DateTime? @map("processed_at")
  refundCompletedAt DateTime? @map("refund_completed_at")

  // 取消
  cancelledAt DateTime? @map("cancelled_at")

  // 拒绝原因
  rejectReason String? @map("reject_reason") @db.Text

  // 时间
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  order  Order @relation(fields: [orderId], references: [id])
  buyer  User  @relation("RefundBuyer", fields: [userId], references: [id])
  seller User  @relation("RefundSeller", fields: [sellerId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("refund_requests")
}

enum RefundStatus {
  PENDING
  SELLER_AGREED
  SELLER_REJECTED
  DISPUTED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

// ==================== 系统配置 ====================

model SystemConfig {

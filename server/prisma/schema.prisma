// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权�?====================

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String? @map("password_hash")
  username     String
  avatar       String?
  phone        String?

  // 第三方登录
  googleId         String? @unique @map("google_id")
  telegramId       String? @unique @map("telegram_id")
  telegramUsername String? @map("telegram_username")

  // 状态
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false) @map("email_verified")
  isSeller      Boolean    @default(false) @map("is_seller")

  // 偏好
  language String @default("zh-CN")
  currency String @default("USD")
  timezone String @default("Asia/Shanghai")

  // 安全
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret")
  recoveryCodes    Json?     @map("recovery_codes")
  lastLoginAt      DateTime? @map("last_login_at")
  lastLoginIp      String?   @map("last_login_ip")
  loginAttempts    Int       @default(0) @map("login_attempts")
  lockedUntil      DateTime? @map("locked_until")

  // 会员系统
  membershipLevel Int     @default(0) @map("membership_level")
  totalSpent      Decimal @default(0.00) @map("total_spent") @db.Decimal(12, 2)
  balance         Decimal @default(0.00) @db.Decimal(12, 2)

  // 推荐系统
  referralCode     String?  @unique @map("referral_code")
  referredBy       String?  @map("referred_by")
  referralRewarded Boolean  @default(false) @map("referral_rewarded")

  // 时间戳
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关联
  roles                  UserRole[]
  sellerProfile          SellerProfile?
  products               Product[]
  ordersAsBuyer          Order[]             @relation("BuyerOrders")
  ordersAsSeller         OrderItem[]         @relation("SellerOrderItems")
  cartItems              CartItem[]
  reviews                Review[]
  favorites              Favorite[]
  tickets                Ticket[]            @relation("UserTickets")
  assignedTickets        Ticket[]            @relation("AssignedTickets")
  ticketMessages         TicketMessage[]
  notifications          Notification[]
  withdrawals            Withdrawal[]
  sellerTransactions     SellerTransaction[]
  blogs                  Blog[]
  blogComments           BlogComment[]
  blogLikes              BlogLike[]
  refundRequestsAsBuyer  RefundRequest[]     @relation("RefundBuyer")
  refundRequestsAsSeller RefundRequest[]     @relation("RefundSeller")

  // 消息系统
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  // 库存系统
  inventories ProductInventory[]

  @@index([email])
  @@index([status])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

// ==================== 角色权限系统 ====================

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      Role
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

enum Role {
  ADMIN
  SELLER
  USER
}

model SellerProfile {
  id              String  @id @default(uuid())
  userId          String  @unique @map("user_id")
  shopName        String  @map("shop_name")
  shopDescription String? @map("shop_description")
  shopAvatar      String? @map("shop_avatar")
  shopBanner      String? @map("shop_banner")

  // 认证信息
  realName        String? @map("real_name")
  idCardNumber    String? @map("id_card_number")
  contactTelegram String? @map("contact_telegram")
  contactEmail    String? @map("contact_email")

  // 等级与状态
  level             SellerLevel       @default(NORMAL)
  applicationStatus ApplicationStatus @default(PENDING) @map("application_status")
  applicationNote   String?           @map("application_note")
  approvedAt        DateTime?         @map("approved_at")
  approvedBy        String?           @map("approved_by")

  // 财务
  balance        Decimal @default(0.00) @db.Decimal(12, 2)
  frozenBalance  Decimal @default(0.00) @map("frozen_balance") @db.Decimal(12, 2)
  totalSales     Decimal @default(0.00) @map("total_sales") @db.Decimal(12, 2)
  totalEarnings  Decimal @default(0.00) @map("total_earnings") @db.Decimal(12, 2)
  totalWithdrawn Decimal @default(0.00) @map("total_withdrawn") @db.Decimal(12, 2)

  // 统计
  productCount Int     @default(0) @map("product_count")
  orderCount   Int     @default(0) @map("order_count")
  soldCount    Int     @default(0) @map("sold_count")
  rating       Decimal @default(5.0) @db.Decimal(2, 1)
  ratingCount  Int     @default(0) @map("rating_count")

  // 佣金
  commissionRate Decimal @default(10.00) @map("commission_rate") @db.Decimal(4, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("seller_profiles")
}

enum SellerLevel {
  NORMAL
  VERIFIED
  PREMIUM
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== 分类 ====================

model Category {
  id           String  @id @default(uuid())
  parentId     String? @map("parent_id")
  name         String
  slug         String  @unique
  icon         String?
  color        String?
  description  String?
  sortOrder    Int     @default(0) @map("sort_order")
  isActive     Boolean @default(true) @map("is_active")
  productCount Int     @default(0) @map("product_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent       Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryHierarchy")
  products     Product[]
  blogs        Blog[]
  //   translations CategoryTranslation[]

  @@map("categories")
}

